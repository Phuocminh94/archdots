{
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "custom/updates": {
    "format": "ΎΗ▓ {}",
    "escape": true,
    "return-type": "json",
    "exec": "update-check",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "ghostty --class=local.floating -e update-perform"
  },
  "custom/hypridle": {
    "format": "ΎΑμ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "hypridle-toggle status",
    "on-click": "hypridle-toggle toggle"
  },
  "custom/music": {
    "format": "ΎΑΒ  {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ title }} - {{artist}}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },
  "clock": {
    "format": "{:%A %H:%M}",
    "format-alt": "{:%d %B %Y}",
    "tooltip": false
  },
  "cpu": {
    "interval": 5,
    "format": "ΎΜδ",
    "on-click": "ghostty -e btop"
  },
  "pulseaudio": {
    "scroll-step": 1,
    "format": "{icon}",
    "on-click": "ghostty --class=local.wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "format-muted": "Ό╗ρ",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ "
      ]
    }
  },
  "network": {
    "format-icons": [
      "≤░νψ",
      "≤░νθ",
      "≤░νλ",
      "≤░νξ",
      "≤░νρ"
    ],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "≤░ΑΓ",
    "format-disconnected": "≤░νχ",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "έΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "ghostty --class=local.floating -e impala"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{icon}",
    "format-charging": "{icon}",
    "format-plugged": "ΎΘο",
    "format-icons": {
      "charging": [
        "≤░λε",
        "≤░ΓΗ",
        "≤░ΓΘ",
        "≤░ΓΙ",
        "≤░λζ",
        "≤░ΓΚ",
        "≤░λη",
        "≤░ΓΛ",
        "≤░ΓΜ",
        "≤░ΓΖ"
      ],
      "default": [
        "≤░Β║",
        "≤░Β╗",
        "≤░Β╝",
        "≤░Β╜",
        "≤░Β╛",
        "≤░Β┐",
        "≤░ΓΑ",
        "≤░ΓΒ",
        "≤░ΓΓ",
        "≤░Β╣"
      ]
    },
    "format-full": "≤░ΓΖ",
    "tooltip-format-discharging": "{power:>1.0f}WέΗΥ {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}WέΗΣ {capacity}%",
    "interval": 5,
    "on-click": "walker -t menus -m menus:power-profiles -N -n",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "bluetooth": {
    "format": "ΎΛΥ",
    "format-disabled": "≤░Γ▓",
    "format-connected": "ΎΛΦ",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "ghostty --class=local.bluetui -e bluetui"
  },
  "custom/brightness": {
    "format": "ΎΗΖ",
    "on-click": "walker -t menus -m menus:brightness --maxheight 350 --minwidth 50 -N"
  },
  "custom/filemanager": {
    "format": "ΎΒ╝",
    "on-click": "nautilus",
    "tooltip-format": "Open Filemanager"
  },
  "custom/screenrecord": {
    "exec": "if [ -f /tmp/screenrecord-filename ]; then start_ts=$(date -r /tmp/screenrecord-filename +%s 2>/dev/null); current_ts=$(date +%s); elapsed=$((current_ts - start_ts)); printf \"≤░ΣΜ %02d:%02d\\n\" $((elapsed / 60)) $((elapsed % 60)); fi",
    "return-type": "json",
    "signal": 8,
    "interval": 1,
    "tooltip": false,
    "on-click": "pkill -SIGINT -f 'gpu-screen-recorder'"
  }
}
