#!/usr/bin/env bash

# animation_frames=("тЦВтЦДтЦЖ" "тЦДтЦВтЦЖ" "тЦДтЦЖтЦВ" "тЦЖтЦДтЦВ" "тЦЖтЦВтЦД")
animation_frames=("яБЛ" "яБЛ" "яБЛ" "яБЛ" "яБЛ")

while :; do
  for frame in "${animation_frames[@]}"; do
    status=$(playerctl metadata --format '{{status}}' 2>/dev/null)

    if [ "$status" == "Playing" ]; then
        echo "$frame"
    elif [ "$status" == "Paused" ]; then
        echo "яБМ"
    else
        echo ""
    fi
    sleep 0.1
  done
done
