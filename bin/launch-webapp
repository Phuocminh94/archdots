#!/bin/bash

if [[ -n "$WEBAPP_BROWSER" ]]; then
  browser="$WEBAPP_BROWSER"
else
  # List of browsers to try (using their standard .desktop filenames)
  browsers=(
    "google-chrome"
    "zen"
    "zen-browser"
  )

  # Find first installed browser .desktop file
  browser_desktop=""
  for b in "${browsers[@]}"; do
    for dir in "$HOME/.local/share/applications" "/usr/share/applications"; do
      # Check for both with and without .desktop suffix
      if [[ -f "$dir/$b.desktop" ]]; then
        browser_desktop="$dir/$b.desktop"
        break 2
      elif [[ -f "$dir/$b" && "$b" == *".desktop" ]]; then
        browser_desktop="$dir/$b"
        break 2
      fi
    done
  done

  if [[ -z "$browser_desktop" ]]; then
    echo "Error: No supported browser found" >&2
    echo "Install one of: ${browsers[*]}" >&2
    exit 1
  fi
fi

# If WEBAPP_BROWSER was used manually without a path, try to locate it
if [[ -z "$browser_desktop" ]]; then
  if [[ -f "$browser" ]]; then
    browser_desktop="$browser"
  else
    browser_desktop=$(find "$HOME/.local/share/applications" "/usr/share/applications" -name "$browser*" -print -quit 2>/dev/null)
  fi
fi

if [[ ! -f "$browser_desktop" ]]; then
  echo "Error: Could not resolve desktop file for browser." >&2
  exit 1
fi

# Safely extract the Exec command, strip field codes (like %U, %F), and grab the binary
exec_cmd=$(sed -n 's/^Exec=\([^ ]*\).*/\1/p' "$browser_desktop" | head -1)

if [[ -z "$exec_cmd" ]]; then
  echo "Error: Could not parse Exec line from $browser_desktop" >&2
  exit 1
fi

# Execute via uwsm
if [[ "$exec_cmd" == *"zen"* || "$exec_cmd" == *"firefox"* ]]; then
  exec setsid uwsm app -- "$exec_cmd" --new-window "$1" "${@:2}"
else
  exec setsid uwsm app -- "$exec_cmd" --app="$1" "${@:2}"
fi
